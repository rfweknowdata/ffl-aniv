NODE_ENV=production
PORT=3000
APP_URL=https://ffl.pt
TZ=Europe/Lisbon

# SQLite lives on the mounted volume in production.
# For local dev, point this at a local file instead, e.g. file:./apps/api/prisma/dev.db
DATA_DIR=/data
DATABASE_URL=file:/data/app.db

# AES-256-GCM key for encrypting the SMTP password at rest (32 bytes, base64).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Web Push (VAPID). Generate with: pnpm gen:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ffl.pt

# Default hour (0-23, Europe/Lisbon) for the daily job if Settings has none yet
SEND_HOUR=8

# Import the 140 seeded members on first boot if the DB is empty (see PLAN.md §9)
SEED_ON_EMPTY=true

# In Docker we use the distro Chromium instead of downloading one.
# Leave unset for local dev so Puppeteer uses its bundled Chromium.
PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
