NODE_ENV=production
PORT=3000
APP_URL=https://ffl.pt
TZ=Europe/Lisbon

# SQLite lives on the mounted volume in production.
# For local dev, point this at a local file instead, e.g. file:./apps/api/prisma/dev.db
DATA_DIR=/data
DATABASE_URL=file:/data/app.db

# AES-256-GCM key for encrypting the SMTP password at rest (32 bytes, base64).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Web Push (VAPID). Generate with: pnpm gen:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ffl.pt

# Default hour (0-23, Europe/Lisbon) for the daily job if Settings has none yet
SEND_HOUR=8

# Import the 140 seeded members on first boot if the DB is empty (see PLAN.md §9)
SEED_ON_EMPTY=true

# Puppeteer uses its own downloaded Chromium build in both dev and prod (see PLAN.md §14 —
# the distro `chromium` package crashed with an unresolved SIGTRAP on the target VPS). Leave
# both unset; only override PUPPETEER_EXECUTABLE_PATH if you have a specific reason to.
PUPPETEER_SKIP_DOWNLOAD=
PUPPETEER_EXECUTABLE_PATH=
